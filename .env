from flask import Blueprint, jsonify
from database import rooms_col, bookings_col
from datetime import datetime

reports_bp = Blueprint('reports', __name__)

@reports_bp.route('/occupancy', methods=['GET'])
def get_occupancy_stats():
    """Calculates what percentage of the hotel is currently full."""
    total_rooms = rooms_col.count_documents({})
    
    # Count rooms currently marked as 'Occupied' or linked to an active booking
    occupied_rooms = rooms_col.count_documents({"status": "Occupied"})
    
    occupancy_rate = (occupied_rooms / total_rooms) * 100 if total_rooms > 0 else 0
    
    return jsonify({
        "total_rooms": total_rooms,
        "occupied_rooms": occupied_rooms,
        "occupancy_percentage": round(occupancy_rate, 2)
    }), 200

@reports_bp.route('/revenue', methods=['GET'])
def get_revenue_report():
    """Uses MongoDB Aggregation to sum up all 'Paid' bookings."""
    pipeline = [
        {"$match": {"payment_status": "Paid"}},
        {"$group": {
            "_id": None, 
            "total_revenue": {"$sum": "$total_bill"},
            "booking_count": {"$sum": 1}
        }}
    ]
    
    result = list(bookings_col.aggregate(pipeline))
    
    if not result:
        return jsonify({"total_revenue": 0, "booking_count": 0}), 200
        
    return jsonify(result[0]), 200